{
  "name": "leaflet",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted markdown note-taking app for general use and CTF/pentest engagements",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.21.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.1.0",
    "@types/better-sqlite3": "^7.6.12",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^17.4.0",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "svelte": "^5.25.6",
    "svelte-check": "^4.1.4",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.2.3",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/language": "^6.11.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.36.3",
    "@google/genai": "^1.44.0",
    "@lucide/svelte": "^0.577.0",
    "@milkdown/core": "^7.6.3",
    "@milkdown/crepe": "^7.6.3",
    "@milkdown/plugin-listener": "^7.19.0",
    "@milkdown/plugin-math": "^7.5.0",
    "@milkdown/plugin-prism": "^7.6.3",
    "@tailwindcss/typography": "^0.5.16",
    "@xyflow/svelte": "^1.5.1",
    "better-sqlite3": "^11.10.0",
    "bits-ui": "^2.3.0",
    "clsx": "^2.1.1",
    "force-graph": "^1.51.1",
    "katex": "^0.16.22",
    "svelte-codemirror-editor": "^2.1.0",
    "tailwind-merge": "^3.1.0",
    "tailwind-variants": "^0.3.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
