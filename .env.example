# ---- AI Provider ----
# Which AI provider to use for the AI assistant.
# Options: gemini (default) | minimax
AI_PROVIDER=gemini

# Google Gemini (default)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# Base URL override (leave unset to use the default Google endpoint)
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# Model to use (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# MiniMax (alternative)
# Sign up at https://www.minimax.io/ and create an API key.
MINIMAX_API_KEY=your-minimax-api-key-here
# Base URL for the MiniMax API (OpenAI-compatible endpoint)
MINIMAX_BASE_URL=https://api.minimax.io/v1
# Model to use (default: MiniMax-M2.5)
MINIMAX_MODEL=MiniMax-M2.5

# ---- Data Directories ----
# Directory where notes.db (SQLite metadata) is stored.
# When running via Docker Compose this is set automatically.
NOTES_DATA_DIR=./data

# Absolute path to the notes markdown directory.
# When running via Docker Compose this is set automatically.
NOTES_DIR=./data/notes

# Absolute path to the screenshots directory.
# When running via Docker Compose this is set automatically.
SCREENSHOTS_DIR=./data/screenshots

# ---- Server ----
# Port for the app (default 5173 dev / 3000 prod).
PORT=5173

# ---- Git Sync ----
# Your name as it should appear on git commits.
GIT_USER_NAME=Your Name

# Your email address as it should appear on git commits.
GIT_USER_EMAIL=you@example.com

# GitHub Personal Access Token for push/pull over HTTPS.
# Create one at: https://github.com/settings/tokens/new
# Required scopes: Contents (read & write) on the target repository.
# Fine-grained token (recommended): Repository > Contents > Read and write
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
