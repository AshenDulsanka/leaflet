# Development Dockerfile for Leaflet.
# Runs pnpm dev with --host so Vite is reachable from outside the container.
# docker compose watch syncs src/ changes in; Vite HMR pushes updates to the browser.

FROM node:22-slim

# Build tools required for native addons (better-sqlite3)
RUN apt-get update && apt-get install -y --no-install-recommends python3 make g++ git && rm -rf /var/lib/apt/lists/*

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# Rebuild native addons for the container architecture
RUN pnpm rebuild better-sqlite3

COPY . .

# Generate .svelte-kit/ (tsconfig.json + route types)
RUN pnpm svelte-kit sync

EXPOSE 5173

CMD ["pnpm", "dev", "--host", "0.0.0.0", "--port", "5173"]
